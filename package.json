{
  "name": "ezclaw",
  "private": true,
  "version": "1.0.0",
  "description": "EZClaw Autonomous AI Agent Desktop Application",
  "main": "src/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run electron:start\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "discord.js": "^14.26.3",
    "electron-store": "^8.2.0",
    "express": "^4.19.2",
    "framer-motion": "^11.5.0",
    "lucide-react": "^0.435.0",
    "node-telegram-bot-api": "^0.67.0",
    "puppeteer": "^23.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^32.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.9.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.1"
  },
  "build": {
    "appId": "com.ezclaw.pc",
    "productName": "EZClaw",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true
    },
    "files": [
      "dist/**/*",
      "src/main.js",
      "src/preload.js",
      "src/services/**/*"
    ]
  }
}
